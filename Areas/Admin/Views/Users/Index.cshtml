@model IEnumerable<Confectionery.Models.User>
@{
    ViewData["Title"] = "👥 Пользователи";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h2 text-primary">
                    <i class="fas fa-users me-2"></i>Пользователи
                    <span class="badge bg-light text-dark fs-6">(@Model.Count())</span>
                </h1>
                <a asp-action="Create" class="btn btn-success btn-lg">
                    <i class="fas fa-plus me-2"></i>Добавить пользователя
                </a>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 80px;">ID</th>
                                <th>Логин</th>
                                <th>Имя</th>
                                <th style="width: 220px;">Email</th>
                                <th style="width: 140px;">Роль</th>
                                <th style="width: 200px;">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong class="text-primary">#@item.Id_User</strong></td>
                                    <td>
                                        <strong>@item.Login</strong>
                                    </td>
                                    <td>@item.Name</td>
                                    <td>@item.Email</td>
                                    <td>
                                        <span class="badge @(item.Role?.Name == "Администратор" ? "bg-warning text-dark" : "bg-primary") fs-6 px-3 py-2">
                                            @item.Role?.Name
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.Id_User" class="btn btn-outline-primary btn-sm me-1">
                                            <i class="fas fa-edit"></i> Изменить
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id_User" class="btn btn-outline-danger btn-sm">
                                            <i class="fas fa-trash"></i> Удалить
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
