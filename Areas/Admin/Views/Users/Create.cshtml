@model Confectionery.Models.User
@{
    ViewData["Title"] = "➕ Добавить пользователя";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h2 class="mb-0"><i class="fas fa-user-plus me-3"></i>Новый пользователь</h2>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Login" class="form-label fw-bold"></label>
                                <input asp-for="Login" class="form-control form-control-lg" />
                                <span asp-validation-for="Login" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-bold"></label>
                                <input asp-for="Name" class="form-control form-control-lg" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-4 mt-3">
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold"></label>
                                <input asp-for="Email" class="form-control form-control-lg" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Password" class="form-label fw-bold"></label>
                                <input asp-for="Password" type="password" class="form-control form-control-lg" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-4 mt-3">
                            <div class="col-md-6">
                                <label asp-for="Id_Role" class="form-label fw-bold">Роль</label>
                                <select asp-for="Id_Role" class="form-select form-select-lg" asp-items="ViewBag.Roles"></select>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex mt-4">
                            <input type="submit" value="Создать" class="btn btn-success btn-lg px-5" />
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5">Отмена</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
