@model List<Confectionery.Models.Catalog>

<h2>🧁 Управление товарами</h2>

<!-- Кнопка создания -->
<a asp-action="CreateProduct" class="btn btn-success mb-3">➕ Добавить товар</a>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Фото</th>
                <th>Название</th>
                <th>Категория</th>
                <th>Цена</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>
                        @if (product.HasPhoto)
                        {
                            <img src="@product.PhotoBase64" style="width:50px;height:50px;object-fit:cover;" class="rounded" />
                        }
                    </td>
                    <td>@product.Product</td>
                    <td>@product.Category.Name</td>
                    <td>@product.Price.ToString("C")</td>
                    <td>
                        <a asp-action="EditProduct" asp-route-id="@product.Id_Catalog" class="btn btn-sm btn-primary">✏️</a>
                        <form asp-action="DeleteProduct" asp-route-id="@product.Id_Catalog" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Удалить?')">🗑️</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
