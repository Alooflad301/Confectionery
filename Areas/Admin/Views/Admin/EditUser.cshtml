@using Confectionery.Models
@model Confectionery.Models.User

<h2>Редактировать пользователя</h2>
<form asp-action="EditUser" method="post">
    <input asp-for="Id_User" type="hidden" />

    <div class="form-group mb-3">
        <label asp-for="Login"></label>
        <input asp-for="Login" class="form-control" />
        <span asp-validation-for="Login" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
    </div>

    <!-- ✅ ИСПРАВЛЕННЫЙ SELECT -->
    <div class="form-group mb-3">
        <label asp-for="Id_Role">Роль</label>
        <select asp-for="Id_Role" class="form-control">
            @foreach (var role in ViewBag.Roles as List<Confectionery.Models.Role>)
            {
                <option value="@role.Id_Role" selected="@(role.Id_Role == Model.Id_Role)">@role.Name</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Сохранить</button>
</form>
