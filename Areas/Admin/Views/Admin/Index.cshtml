@{
    ViewData["Title"] = "Дашборд - Админ панель";
    dynamic stats = ViewBag.Stats;
}

<div class="container-fluid py-4">
    <!-- СТАТИСТИКА -->
    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-lg-6 col-md-6">
            <div class="card h-100 shadow-lg border-0">
                <div class="card-body text-center p-4">
                    <i class="fas fa-users fa-3x text-primary mb-3"></i>
                    <h3 class="fw-bold text-primary">@(stats?.UsersCount ?? 0)</h3>
                    <p class="text-muted mb-0">Пользователей</p>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6 col-md-6">
            <div class="card h-100 shadow-lg border-0">
                <div class="card-body text-center p-4">
                    <i class="fas fa-shopping-bag fa-3x text-success mb-3"></i>
                    <h3 class="fw-bold text-success">@(stats?.OrdersCount ?? 0)</h3>
                    <p class="text-muted mb-0">Заказов</p>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6 col-md-6">
            <div class="card h-100 shadow-lg border-0">
                <div class="card-body text-center p-4">
                    <i class="fas fa-ruble-sign fa-3x text-warning mb-3"></i>
                    <h3 class="fw-bold text-warning">@((stats?.TotalRevenue ?? 0).ToString("C"))</h3>
                    <p class="text-muted mb-0">Выручка</p>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6 col-md-6">
            <div class="card h-100 shadow-lg border-0">
                <div class="card-body text-center p-4">
                    <i class="fas fa-cookie-bite fa-3x text-info mb-3"></i>
                    <h3 class="fw-bold text-info">@(stats?.ProductsCount ?? 0)</h3>
                    <p class="text-muted mb-0">Товаров</p>
                </div>
            </div>
        </div>
    </div>

    <!-- БЫСТРЫЕ ССЫЛКИ -->
    <div class="row g-4">
        <div class="col-lg-3 col-md-6">
            <a asp-action="Users" class="text-decoration-none">
                <div class="card h-100 shadow-lg border-0 hover-card">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-users fa-3x text-primary mb-3"></i>
                        <h4 class="mb-2">Пользователи</h4>
                        <p class="text-muted mb-0">Управление аккаунтами</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-lg-3 col-md-6">
            <a asp-action="Orders" class="text-decoration-none">
                <div class="card h-100 shadow-lg border-0 hover-card">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-shopping-bag fa-3x text-success mb-3"></i>
                        <h4 class="mb-2">Заказы</h4>
                        <p class="text-muted mb-0">Обработка заказов</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-lg-3 col-md-6">
            <a asp-action="Products" class="text-decoration-none">
                <div class="card h-100 shadow-lg border-0 hover-card">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-cookie-bite fa-3x text-warning mb-3"></i>
                        <h4 class="mb-2">Товары</h4>
                        <p class="text-muted mb-0">Каталог товаров</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-lg-3 col-md-6">
            <a asp-controller="Categories" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 shadow-lg border-0 hover-card">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-tags fa-3x text-info mb-3"></i>
                        <h4 class="mb-2">Категории</h4>
                        <p class="text-muted mb-0">Управление категориями</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: all 0.3s ease;
    }

        .hover-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
        }
</style>
