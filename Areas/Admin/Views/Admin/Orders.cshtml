@using Confectionery.Models
@model List<Confectionery.Models.Order>

<h2>📦 Все заказы</h2>

@foreach (var order in Model)
{
    <div class="card mb-3">
        <div class="card-header">
            <strong>Заказ #@order.Id_Order</strong> | @order.User.Name | @order.Date.ToString("dd.MM HH:mm")
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <strong>Статус:</strong><br>
                    <select asp-for="Id_StatusOrder" onchange="updateStatus(@order.Id_Order, this.value)" class="form-select">
                        @foreach (var status in ViewBag.Statuses as List<StatusOrder>)
                        {
                            <option value="@status.Id_StatusOrder" selected="@(status.Id_StatusOrder == order.Id_StatusOrder)">@status.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <strong>Итого: @order.Price.ToString("C")</strong>
                </div>
            </div>
        </div>
    </div>
}

<script>
    function updateStatus(idOrder, statusId) {
        fetch(`/Admin/UpdateOrderStatus?idOrder=${idOrder}&idStatus=${statusId}`, { method: 'POST' })
            .then(() => location.reload());
    }
</script>

