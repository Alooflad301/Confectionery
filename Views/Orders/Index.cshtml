@model IEnumerable<Confectionery.Models.Order>
@{
    ViewData["Title"] = "📦 Все заказы";
}

<div class="orders-index py-5 bg-light">
    <div class="container">
        <!-- ЗАГОЛОВОК -->
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold text-primary mb-3">📦 Все заказы</h1>
            <p class="lead text-muted">Управление заказами</p>
        </div>

        <!-- ТАБЛИЦА ЗАКАЗОВ -->
        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary text-white py-4">
                <h3 class="mb-0">
                    <i class="fas fa-list me-2"></i>Список заказов
                </h3>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Клиент</th>
                                <th>Статус</th>
                                <th>Дата</th>
                                <th>Сумма</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="align-middle">
                                    <!-- ID -->
                                    <td>
                                        <span class="badge bg-secondary fs-6">#@item.Id_Order</span>
                                    </td>

                                    <!-- Клиент -->
                                    <td>
                                        <div class="user-info">
                                            <div class="fw-bold">@(item.User?.Name ?? item.User?.Login ?? "N/A")</div>
                                            <small class="text-muted">@(item.User?.Email ?? "")</small>
                                        </div>
                                    </td>

                                    <!-- Статус -->
                                    <td>
                                        <span class="badge
                                                @(item.StatusOrder.Name == "Выполнен" ? "bg-success" :
                                                                                            item.StatusOrder.Name == "Отменен" ? "bg-danger" :
                                                                                            item.StatusOrder.Name == "Новый" ? "bg-warning" :
                                                                                            item.StatusOrder.Name == "В доставке" ? "bg-info" : "bg-primary")
                                            fs-6 px-3 py-2">
                                        @item.StatusOrder.Name
                                    </span>
                                </td>

                                    <!-- Дата -->
                                    <td>
                                        <div>
                                            <div class="fw-bold">@item.Date.ToString("dd.MM")</div>
                                            <small class="text-muted">@item.Date.ToString("HH:mm")</small>
                                        </div>
                                    </td>

                                    <!-- Сумма -->
                                    <td>
                                        <div class="h5 fw-bold text-success mb-0">@item.Price.ToString("C")</div>
                                    </td>

                                    <!-- ДЕЙСТВИЯ (только детали + редактирование) -->
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@item.Id_Order"
                                               class="btn btn-outline-primary btn-sm me-1" title="Подробнее">
                                                <i class="fas fa-eye me-1"></i>Подробности
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id_Order"
                                               class="btn btn-outline-warning btn-sm" title="Изменить статус">
                                                <i class="fas fa-edit me-1"></i>Редактировать
                                            </a>
                                        </div>
                                    </td>

                                </tr>
                                                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

</table>
