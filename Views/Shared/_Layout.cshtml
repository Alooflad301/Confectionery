<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Confectionery</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Confectionery.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/catalog.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminUsers.css" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />


</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/image/Logotip.png" alt="Logo" style="height: 90px;">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Главная страница</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Catalogs" asp-action="Index">Каталог</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Catalogs" asp-action="Basket">🛒 Корзина</a>
                        </li>
                        <li class="nav-item dropdown ms-3">
                            <partial name="_ProfilePartial" />
                        </li>
                        @if (User.IsInRole("Администратор"))
                        {
                            <li class="nav-item dropdown ms-3">
                                <partial name="_AdminPartial" />
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center" >
            &copy; 2026 - Все прова защищены
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        let adminData = {};

        // Загрузка статистики при загрузке страницы
        $(document).ready(function() {
            if (@Json.Serialize(User.IsInRole("Администратор"))) {
                loadAdminStats();
            }
        });

        function loadAdminStats() {
            $.get('/Admin/GetAdminData', function(data) {
                adminData = data;
                $('#admin-users-count').text(data.usersCount || 0);
                $('#admin-orders-count').text(data.ordersCount || 0);
                $('#admin-products-count').text(data.productsCount || 0);
            }).fail(function() {
                $('#admin-users-count, #admin-orders-count, #admin-products-count').text('—');
            });
        }

        function reloadAdminStats() {
            loadAdminStats();
        }

        function showAdminSection(section) {
            hideAdminSections();
            $('#admin-' + section + '-section').show();
            $('html, body').animate({ scrollTop: $('#admin-' + section + '-section').offset().top - 100 }, 500);

            // Загружаем данные секции
            loadAdminSectionData(section);
        }

        function hideAdminSections() {
            $('.admin-section').hide();
        }

        function loadAdminSectionData(section) {
            const sections = {
                'users': '/Admin/GetUsers',
                'orders': '/Admin/GetOrders',
                'products': '/Admin/GetProducts'
            };

            if (sections[section]) {
                $.get(sections[section], function(data) {
                    $('#admin-' + section + '-list').html(data);
                });
            }
        }
    </script>


</body>
</html>
