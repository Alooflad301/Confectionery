@model Confectionery.Models.Catalog
@{
    ViewData["Title"] = Model.Product;
}

<div class="product-details">
    <a asp-action="Index" class="back-link">
        <i class="fas fa-arrow-left"></i> Назад к каталогу
    </a>

    <div class="row">
        <div class="col-lg-6">
            <div class="product-image-large">
                @if (Model.Photo != null)
                {
                    <img src="data:@Model.PhotoContentType;base64,@Convert.ToBase64String(Model.Photo)"
                         alt="@Model.Product" />
                }
                else
                {
                    <img src="~/images/no-image.png" alt="Нет изображения" />
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="product-info-details">
                <h1>@Model.Product</h1>
                <div class="category-badge">@Model.Category?.Name</div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="full-description">
                        <h3>Описание</h3>
                        <p>@Html.Raw(Model.Description)</p>
                    </div>
                }

                <div class="add-to-cart-section">
                    <form asp-action="AddToBasket" method="post" class="add-to-cart-large">
                        <input type="hidden" name="catalogId" value="@Model.Id_Catalog" />
                        <div class="quantity-selector">
                            <label>Количество:</label>
                            <input type="number" name="quantity" value="1" min="1" max="99" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="fas fa-shopping-cart"></i> Добавить в корзину
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
