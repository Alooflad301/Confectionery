@model Confectionery.Models.Catalog
@{
    ViewData["Title"] = "Редактировать товар";
}

<div class="container my-5">
    <h2 class="mb-4">
        <i class="fas fa-edit me-2 text-warning"></i>
        Редактировать: @Model.Product
    </h2>

    <!-- 🔥 ОШИБКИ -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-warning">
            <strong>Ошибки:</strong>
            @foreach (var error in ViewData.ModelState)
            {
                if (error.Value.Errors.Count > 0)
                {
                    <div>@error.Key: @error.Value.Errors[0].ErrorMessage</div>
                }
            }
        </div>
    }

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id_Catalog" />

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-box me-2"></i>Основная информация</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Product" class="form-label">Название <span class="text-danger">*</span></label>
                                <input asp-for="Product" class="form-control" required />
                                <span asp-validation-for="Product" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Id_Ctegory" class="form-label">Категория <span class="text-danger">*</span></label>
                                <select asp-for="Id_Ctegory" class="form-select" required>
                                    <option value="">Выберите категорию</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        @foreach (var category in ViewBag.Categories as List<Confectionery.Models.Category>)
                                        {
                                            <option value="@category.Id_Category"
                                                    selected="@(category.Id_Category == Model.Id_Ctegory)">
                                                @category.Name
                                            </option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Описание</label>
                            <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label">Цена (₽) <span class="text-danger">*</span></label>
                            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" required />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <!-- Добавь ПОСЛЕ поля цены -->
                        <!-- То же самое поле после цены -->
                        <div class="mb-3">
                            <label class="form-label">Картинка</label>
                            <div class="input-group">
                                <span class="input-group-text">/images/</span>
                                <input asp-for="PhotoPath" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                @if (Model.HasPhoto)
                {
                    <div class="card shadow mt-3">
                        <div class="card-body text-center p-4">
                            <h6 class="text-muted mb-3">Текущее изображение</h6>
                            <img src="@Model.PhotoBase64" class="img-fluid rounded shadow" style="max-height: 200px;" />
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="mt-5 pt-4 border-top">
            <div class="d-flex gap-3 justify-content-end">
                <a asp-action="Index" class="btn btn-secondary btn-lg">
                    <i class="fas fa-arrow-left me-2"></i>Назад
                </a>
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="fas fa-save me-2"></i>Сохранить
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
