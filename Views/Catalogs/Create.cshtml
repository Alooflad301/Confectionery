@model Confectionery.Models.Catalog
@{
    ViewData["Title"] = "Добавить товар";
}

<div class="container my-5">
    <h2 class="mb-4">
        <i class="fas fa-plus me-2 text-success"></i>
        Добавить новый товар
    </h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form asp-action="Create" method="post">
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-box me-2"></i>Основная информация</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Product" class="form-label">Название товара <span class="text-danger">*</span></label>
                                <input asp-for="Product" class="form-control" required />
                                <span asp-validation-for="Product" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Id_Ctegory" class="form-label">Категория <span class="text-danger">*</span></label>
                                <select asp-for="Id_Ctegory" class="form-select" required>
                                    <option value="">Выберите категорию</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        @foreach (var category in ViewBag.Categories as List<Confectionery.Models.Category>)
                                        {
                                            <option value="@category.Id_Category">@category.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="Id_Ctegory" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Описание</label>
                            <textarea asp-for="Description" rows="4" class="form-control" maxlength="1000"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label">Цена (₽) <span class="text-danger">*</span></label>
                            <input asp-for="Price" type="number" step="0.01" min="0" max="100000" class="form-control" required />
                            <span asp-validation-for="Price" class="text-danger"></span>
                            <div class="form-text">Максимум 100 000 ₽</div>
                        </div>
                        <!-- После поля цены -->
                        <div class="mb-3">
                            <label class="form-label">Картинка</label>
                            <div class="input-group">
                                <span class="input-group-text">/images/</span>
                                <input asp-for="PhotoPath" class="form-control" placeholder="cake1.jpg" />
                            </div>
                            <div class="form-text">Положи картинку в wwwroot/images/</div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model?.PhotoPath))
                        {
                            <div class="card shadow mt-3">
                                <div class="card-body text-center p-4">
                                    <h6 class="card-title text-muted mb-3">Предпросмотр</h6>
                                    <img src="~/images/@Model.PhotoPath"
                                         class="img-fluid rounded shadow"
                                         style="max-height: 200px; object-fit: cover;"
                                         onerror="this.style.display='none'" />
                                    <small class="text-muted d-block mt-2">
                                        Путь: /images/@Model.PhotoPath
                                    </small>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-lg border-0 h-100">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Информация</h6>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Фото добавляется отдельно</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Товар сразу появится в каталоге</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Обязательные поля отмечены *</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Кнопки -->
        <div class="mt-5 pt-4 border-top">
            <div class="d-flex gap-3 justify-content-end">
                <a asp-action="Index" class="btn btn-secondary btn-lg">
                    <i class="fas fa-arrow-left me-2"></i>Назад к каталогу
                </a>
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="fas fa-plus me-2"></i>Добавить товар
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
