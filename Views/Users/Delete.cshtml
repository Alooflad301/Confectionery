@model Confectionery.Models.User
@{
    ViewData["Title"] = "Удалить пользователя";
}
<head>
    <link rel="stylesheet" href="~/css/DeleteUser.css" asp-append-version="true" />
</head>
<div class="delete-page py-5 bg-gradient-danger">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-6">
                <!-- ⚠️ КАРТОЧКА УДАЛЕНИЯ -->
                <div class="delete-card card shadow-lg border-0 overflow-hidden">
                    <!-- ЗАГОЛОВОК -->
                    <div class="card-header bg-danger text-white p-5 position-relative">
                        <div class="delete-icon-container">
                            <i class="fas fa-user-times fa-3x"></i>
                        </div>
                        <h2 class="mb-1 fw-bold">Удалить пользователя?</h2>
                        <p class="lead mb-0 opacity-90">
                            Вы уверены, что хотите удалить <strong>@Model.Login</strong>?
                        </p>
                    </div>

                    <!-- ИНФОРМАЦИЯ -->
                    <div class="card-body p-5">
                        <div class="row g-4">
                            <!-- Логин -->
                            <div class="col-md-6">
                                <div class="info-item">
                                    <i class="fas fa-user icon-primary"></i>
                                    <div>
                                        <label class="fw-bold text-muted small">Логин</label>
                                        <div class="h6 fw-bold text-dark">@Model.Login</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Имя -->
                            <div class="col-md-6">
                                <div class="info-item">
                                    <i class="fas fa-user-tag icon-success"></i>
                                    <div>
                                        <label class="fw-bold text-muted small">Имя</label>
                                        <div class="h6 text-dark">@(Model.Name ?? "Не указано")</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Роль -->
                            <div class="col-md-6">
                                <div class="info-item">
                                    <i class="fas fa-crown icon-warning"></i>
                                    <div>
                                        <label class="fw-bold text-muted small">Роль</label>
                                        <div class="h6">
                                            <span class="badge bg-warning text-dark fs-6 px-3 py-2">@Model.Role?.Name</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="col-md-6">
                                <div class="info-item">
                                    <i class="fas fa-envelope icon-info"></i>
                                    <div>
                                        <label class="fw-bold text-muted small">Email</label>
                                        <div class="h6 text-dark">@(Model.Email ?? "Не указан")</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ПРЕДУПРЕЖДЕНИЕ -->
                        <div class="alert alert-warning mt-4 border-0 shadow-sm">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>Внимание!</strong> После удаления пользователя все его данные
                            (заказы, корзина) будут безвозвратно удалены.
                        </div>
                    </div>

                    <!-- КНОПКИ -->
                    <div class="card-footer bg-light border-0 p-4">
                        <div class="delete-buttons d-flex gap-3 justify-content-center">
                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" asp-for="Id_User" />
                                <button type="submit" class="btn btn-danger btn-lg px-5 py-3 fw-bold shadow-lg">
                                    <i class="fas fa-trash-alt me-2"></i>Да, удалить
                                </button>
                            </form>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 py-3 fw-bold shadow-lg">
                                <i class="fas fa-times me-2"></i>Отмена
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


