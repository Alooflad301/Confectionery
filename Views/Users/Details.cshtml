@model Confectionery.Models.User
@{
    ViewData["Title"] = $"👤 {Model.Login} — Подробности";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <!-- Заголовок -->
            <div class="text-center mb-5 admin-fade-in">
                <div class="avatar-container mb-4">
                    <div class="avatar admin-avatar-large @(Model.Role?.Name == "Администратор" ? "admin-avatar-gold" : "admin-avatar-blue")">
                        <i class="fas @(Model.Role?.Name == "Администратор" ? "fa-crown" : "fa-user") fa-2x"></i>
                    </div>
                </div>
                <h1 class="display-5 fw-bold text-primary mb-2">
                    @Model.Login
                </h1>
                <h3 class="h4 text-muted mb-1">@Model.Name</h3>
                <span class="badge @(Model.Role?.Name == "Администратор" ? "admin-role-admin fs-5 px-4 py-3" : "admin-role-user fs-5 px-4 py-3")">
                    <i class="fas @(Model.Role?.Name == "Администратор" ? "fa-shield-alt me-1" : "fa-user me-1")"></i>
                    @Model.Role?.Name
                </span>
            </div>

            <!-- Основная карточка -->
            <div class="card shadow-xl admin-card h-100">
                <div class="card-header admin-gradient-primary text-white py-4">
                    <h3 class="mb-0">
                        <i class="fas fa-info-circle me-3"></i>Основная информация
                    </h3>
                </div>
                <div class="card-body py-5">
                    <div class="row g-5">
                        <!-- Левая колонка -->
                        <div class="col-lg-6">
                            <div class="info-item">
                                <div class="info-label">
                                    <i class="fas fa-user-circle text-primary me-2"></i>
                                    Логин
                                </div>
                                <div class="info-value fw-bold fs-5">@Model.Login</div>
                            </div>

                            <div class="info-item">
                                <div class="info-label">
                                    <i class="fas fa-user-tag text-success me-2"></i>
                                    Имя
                                </div>
                                <div class="info-value">@(Model.Name ?? "—")</div>
                            </div>

                            <div class="info-item">
                                <div class="info-label">
                                    <i class="fas fa-shield-alt text-warning me-2"></i>
                                    Роль
                                </div>
                                <div class="info-value">
                                    <span class="badge @(Model.Role?.Name == "Администратор" ? "admin-role-admin" : "admin-role-user") fs-6 px-3 py-2">
                                        @Model.Role?.Name
                                    </span>
                                </div>
                            </div>

                            <div class="info-item">
                                <div class="info-label">
                                    <i class="fas fa-id-card text-info me-2"></i>
                                    ID пользователя
                                </div>
                                <div class="info-value fw-mono">#@Model.Id_User</div>
                            </div>
                        </div>

                        <!-- Правая колонка -->
                        <div class="col-lg-6">
                            <div class="info-item">
                                <div class="info-label">
                                    <i class="fas fa-envelope text-danger me-2"></i>
                                    Email
                                </div>
                                <div class="info-value">@(Model.Email ?? "Не указан")</div>
                            </div>

                            <div class="info-item">
                                <div class="info-label">
                                    <i class="fas fa-calendar text-secondary me-2"></i>
                                    ID роли
                                </div>
                                <div class="info-value fw-mono">@Model.Id_Role</div>
                            </div>

                            <div class="info-item">
                                <div class="info-label">
                                    <i class="fas fa-key text-muted me-2"></i>
                                    Пароль
                                </div>
                                <div class="info-value">
                                    <span class="badge bg-secondary">
                                        <i class="fas fa-eye-slash me-1"></i>Скрыт
                                    </span>
                                </div>
                            </div>
                                <div class="d-flex justify-content-center gap-3">
                                    <a asp-action="Edit" asp-route-id="@Model.Id_User"
                                       class="btn btn-primary btn-lg px-5 py-2">
                                        <i class="fas fa-edit me-2"></i>Редактировать
                                    </a>
                                </div>
                                <div class="d-flex justify-content-center gap-3">
                                    <a asp-action="Index"
                                       class="btn btn-outline-secondary btn-lg px-5 py-2">
                                        <i class="fas fa-arrow-left me-2"></i>К списку
                                    </a>
                                </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
