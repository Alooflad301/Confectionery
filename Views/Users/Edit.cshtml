@model Confectionery.Models.User
@{
    ViewData["Title"] = $"✏️ Редактировать {Model.Login}";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <!-- Заголовок -->
            <div class="text-center mb-5 admin-fade-in">
                <div class="avatar-container mb-4">
                    <div class="avatar admin-avatar-large @(Model.Role?.Name == "Администратор" ? "admin-avatar-gold" : "admin-avatar-blue")">
                        <i class="fas @(Model.Role?.Name == "Администратор" ? "fa-crown" : "fa-user") fa-2x"></i>
                    </div>
                </div>
                <h1 class="display-5 fw-bold text-primary mb-2">Редактировать</h1>
                <h2 class="h4 text-muted mb-3">@Model.Login</h2>
            </div>

            <!-- Форма -->
            <div class="card shadow-xl admin-card">
                <div class="card-header admin-gradient-primary text-white py-4">
                    <h3 class="mb-0">
                        <i class="fas fa-user-edit me-3"></i>Редактировать пользователя
                    </h3>
                </div>
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger m-4"></div>
                    <input type="hidden" asp-for="Id_User" />

                    <div class="card-body py-5">
                        <div class="row g-4">
                            <!-- Левая колонка -->
                            <div class="col-lg-6">
                                <div class="form-floating mb-4">
                                    <input asp-for="Login" class="form-control form-control-lg"
                                           id="floatingLogin" required />
                                    <label for="floatingLogin">
                                        <i class="fas fa-user-circle text-primary me-2"></i>Логин *
                                    </label>
                                    <span asp-validation-for="Login" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-floating mb-4">
                                    <input asp-for="Name" class="form-control form-control-lg"
                                           id="floatingName" required />
                                    <label for="floatingName">
                                        <i class="fas fa-user-tag text-success me-2"></i>Имя *
                                    </label>
                                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-floating mb-4">
                                    <input asp-for="Email" type="email" class="form-control form-control-lg"
                                           id="floatingEmail" />
                                    <label for="floatingEmail">
                                        <i class="fas fa-envelope text-danger me-2"></i>Email
                                    </label>
                                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <!-- Правая колонка -->
                            <!-- ✅ РОЛИ — УВЕЛИЧЕННАЯ ШИРИНА -->
                            <div class="col-lg-6">
                                <div class="form-floating mb-4">
                                    <select asp-for="Id_Role" class="form-select form-select-lg admin-role-select" id="floatingRole" required>
                                        <option value="">Выберите роль</option>
                                        <option value="1" selected="@(Model.Id_Role == 1)">👤 Пользователь</option>
                                        <option value="2" selected="@(Model.Id_Role == 2)">👑 Администратор</option>
                                    </select>
                                    <label for="floatingRole">
                                        <i class="fas fa-user-shield text-info me-2"></i>Роль *
                                    </label>
                                    <span asp-validation-for="Id_Role" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Кнопки -->
                    <div class="card-footer bg-light border-0 py-4">
                        <div class="d-flex justify-content-center gap-3">
                            <button type="submit" class="btn btn-success btn-lg px-5 py-2">
                                <i class="fas fa-save me-2"></i>Сохранить изменения
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 py-2">
                                <i class="fas fa-arrow-left me-2"></i>К списку
                            </a>
                            <a asp-action="Details" asp-route-id="@Model.Id_User" class="btn btn-outline-primary btn-lg px-5 py-2">
                                <i class="fas fa-eye me-2"></i>Посмотреть
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
