@model Confectionery.Models.BasketCatalog

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>BasketCatalog</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id_BasketCatalog" />
            <div class="form-group">
                <label asp-for="Id_Basket" class="control-label"></label>
                <select asp-for="Id_Basket" class="form-control" asp-items="ViewBag.Id_Basket"></select>
                <span asp-validation-for="Id_Basket" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Id_Catalog" class="control-label"></label>
                <select asp-for="Id_Catalog" class="form-control" asp-items="ViewBag.Id_Catalog"></select>
                <span asp-validation-for="Id_Catalog" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
