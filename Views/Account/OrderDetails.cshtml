@model Confectionery.Models.Order
@{
    ViewData["Title"] = $"Заказ #{Model.Id_Order}";
}

<div class="order-details-page py-5 bg-gradient-orders">
    <div class="container">
        <!-- НАЗАД -->
        <a asp-action="Orders" class="btn btn-outline-primary mb-4 shadow-sm">
            <i class="fas fa-arrow-left me-2"></i>К списку заказов
        </a>

        <div class="row g-4">
            <!-- ИНФОРМАЦИЯ О ЗАКАЗЕ -->
            <div class="col-lg-4">
                <div class="order-info-card card shadow-lg border-0 h-100">
                    <div class="card-header bg-white border-0 py-4">
                        <h3 class="mb-0">
                            <i class="fas fa-receipt me-2 text-primary"></i>Заказ #@Model.Id_Order
                        </h3>
                    </div>
                    <div class="card-body p-4">
                        <div class="info-row">
                            <span class="label">Дата:</span>
                            <span class="value">@Model.Date.ToString("dd MMMM yyyy, HH:mm")</span>
                        </div>
                        <div class="info-row">
                            <span class="label">Статус:</span>
                            <span class="status-badge status-@Model.StatusOrder?.Name?.ToLower()">
                                @Model.StatusOrder?.Name
                            </span>
                        </div>
                        <div class="info-row border-top pt-3 mt-3">
                            <span class="label fw-bold">Итого:</span>
                            <span class="value h3 text-success mb-0">@Model.Price.ToString("C")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ТОВАРЫ В ЗАКАЗЕ -->
            <div class="col-lg-8">
                <div class="order-items-card card shadow-lg border-0 h-100">
                    <div class="card-header bg-white border-0 py-4">
                        <h3 class="mb-0">
                            <i class="fas fa-boxes me-2 text-success"></i>
                            Товары (@Model.OrderCatalogs?.Count() шт.)
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.OrderCatalogs != null && Model.OrderCatalogs.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Товар</th>
                                            <th>Цена</th>
                                            <th>Кол-во</th>
                                            <th>Сумма</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.OrderCatalogs!)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        @if (item.Catalog.HasPhoto)
                                                        {
                                                            <img src="@item.Catalog.PhotoBase64"
                                                                 style="width:50px;height:50px;object-fit:cover;border-radius:8px;"
                                                                 class="me-3 shadow-sm" />
                                                        }
                                                        <div>
                                                            <div class="fw-bold">@item.Catalog.Product</div>
                                                            <small class="text-muted">@item.Catalog.Category?.Name</small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td><strong>@item.Catalog.Price.ToString("C")</strong></td>
                                                <td><span class="badge bg-primary">@item.Quantity шт.</span></td>
                                                <td><strong class="text-success">@((item.Quantity * item.Catalog.Price).ToString("C"))</strong></td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="table-light">
                                        <tr class="fw-bold">
                                            <td colspan="3" class="text-end">ИТОГО:</td>
                                            <td class="text-success h5">@Model.Price.ToString("C")</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                <p class="text-muted">Товары не найдены</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
