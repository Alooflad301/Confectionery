@model List<Confectionery.Models.Order>
@{
    ViewData["Title"] = "Мои заказы";
}

<div class="orders-page py-5">
    <div class="container">
        <div class="page-header text-center mb-5">
            <h1 class="display-4 fw-bold mb-3">
                <i class="fas fa-shopping-bag text-primary me-3"></i>Мои заказы
            </h1>
            <p class="lead text-muted">История ваших покупок в кондитерской</p>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-orders text-center py-5 my-5">
                <i class="fas fa-inbox fa-4x text-muted mb-4"></i>
                <h3 class="text-muted mb-4">У вас пока нет заказов</h3>
                <p class="mb-4">Совершите первую покупку в нашем каталоге!</p>
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-lg">
                    <i class="fas fa-cookie-bite me-2"></i>Перейти в каталог
                </a>
            </div>
        }
        else
        {
            <div class="orders-list">
                @foreach (var order in Model)
                {
                    <div class="order-card card shadow-lg mb-4 border-0 overflow-hidden">
                        <!-- ЗАГОЛОВОК ЗАКАЗА -->
                        <div class="card-header bg-gradient-primary text-white p-4 position-relative">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h3 class="mb-1 fw-bold">Заказ #@order.Id_Order</h3>
                                    <!-- В заголовке заказа добавь количество товаров -->
                                    <div class="order-meta">
                                        <span class="badge bg-light text-dark me-2">@order.Date.ToString("dd.MM.yyyy HH:mm")</span>
                                        <span class="badge bg-info text-dark me-2">@(order.OrderCatalogs?.Count() ?? 0) товаров</span>
                                        <span class="status-badge status-@order.StatusOrder?.Name?.ToLower()">
                                            @order.StatusOrder?.Name
                                        </span>
                                    </div>

                                </div>
                                <div class="order-total text-end">
                                    <div class="h4 mb-0">@order.Price.ToString("C")</div>
                                    <small class="opacity-75">Итого</small>
                                </div>
                            </div>
                        </div>

                        <!-- СОДЕРЖИМОЕ ЗАКАЗА -->
                        <div class="card-body p-0">
                            <a asp-action="OrderDetails" asp-route-id="@order.Id_Order" class="btn btn-link p-4 w-100 text-start">
                                <i class="fas fa-chevron-right me-3 opacity-50"></i>
                                <span>Подробнее о заказе</span>
                            </a>
                        </div>
                    </div>
                }
            </div>

            <!-- ПАГИНАЦИЯ (если много заказов) -->
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    <li class="page-item disabled">
                        <a class="page-link">Предыдущая</a>
                    </li>
                    <li class="page-item active">
                        <a class="page-link" href="#">1</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="#">2</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="#">Следующая</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
