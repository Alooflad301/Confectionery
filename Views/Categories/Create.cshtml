@model Confectionery.Models.Category
@{
    ViewData["Title"] = "Добавить категорию";
}

<div class="container my-5">
    <h2 class="mb-4">
        <i class="fas fa-folder-plus me-2 text-info"></i>
        Добавить новую категорию
    </h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form asp-action="Create" method="post">
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-tag me-2"></i>Информация о категории</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Название категории <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required maxlength="100" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Описание</label>
                            <textarea asp-for="Description" rows="3" class="form-control" maxlength="500"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-lg border-0 h-100">
                    <div class="card-header bg-secondary text-white">
                        <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Подсказка</h6>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled">
                            <li><i class="fas fa-check text-success me-2"></i>Обязательно название</li>
                            <li><i class="fas fa-check text-success me-2"></i>Категория сразу в каталоге</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 pt-4 border-top">
            <div class="d-flex gap-3 justify-content-end">
                <a asp-controller="Catalogs" asp-action="Index" class="btn btn-secondary btn-lg">
                    <i class="fas fa-arrow-left me-2"></i>К каталогу
                </a>
                <button type="submit" class="btn btn-info btn-lg">
                    <i class="fas fa-plus me-2"></i>Добавить категорию
                </button>
            </div>
        </div>
    </form>
</div>
