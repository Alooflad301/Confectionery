@model Confectionery.Models.Category
@{
    ViewData["Title"] = Model.Name;
}

<div class="category-details">
    <div class="back-link">
        <a asp-action="Index"><i class="fas fa-arrow-left"></i> Все категории</a>
    </div>

    <div class="category-header">
        <h1>@Model.Name</h1>
        <div class="category-stats">
            <span>@Model.ProductsCount товаров</span>
        </div>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="category-description">@Model.Description</p>
        }
    </div>

    <!-- Товары категории -->
    <div class="products-grid">
        @if (Model.Catalogs != null && Model.Catalogs.Any())
        {
            @foreach (var product in Model.Catalogs)
            {
                <div class="product-card-small">
                    @if (product.HasPhoto)
                    {
                        <img src="@product.PhotoBase64" alt="@product.Product" />
                    }
                    <div class="product-info-small">
                        <h4>@product.Product</h4>
                        <div class="price">@product.PriceDisplay</div>
                        <a asp-controller="Catalog" asp-action="Details" asp-route-id="@product.Id_Catalog"
                           class="btn btn-sm btn-outline-primary">Подробнее</a>
                    </div>
                </div>
            }
        }
        else
        {
            <p>В этой категории пока нет товаров</p>
        }
    </div>
</div>
