@model List<Confectionery.Models.Category>
@{
    ViewData["Title"] = "Категории";
}

<div class="categories-page">
    <div class="page-header">
        <h1>Категории</h1>
        <a asp-action="Index" asp-controller="Catalog" class="btn btn-primary">К каталогу</a>
    </div>

    <div class="categories-grid">
        @foreach (var category in Model)
        {
            <div class="category-card">
                <div class="category-info">
                    <h3>@category.Name</h3>
                    <p>@category.ProductsCount товаров</p>
                    @if (!string.IsNullOrEmpty(category.Description))
                    {
                        <p class="description">@category.Description</p>
                    }
                    <div class="category-actions">
                        <a asp-action="Details" asp-route-id="@category.Id_Category"
                           class="btn btn-outline-primary">Подробнее</a>
                        <a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="@category.Id_Category"
                           class="btn btn-primary">В каталог</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
